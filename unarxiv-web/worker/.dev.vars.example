# Copy to .dev.vars for local development:
#   cp .dev.vars.example .dev.vars
#
# These override wrangler.toml [vars] and provide secrets locally.
# .dev.vars is gitignored — never commit it.

ADMIN_PASSWORD=localdev
MODAL_WEBHOOK_SECRET=localdev
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# MODAL_FUNCTION_URL is a secret (not in wrangler.toml) — set it here for local dev
# or via `wrangler secret put MODAL_FUNCTION_URL` for production.
# Leave blank locally; the worker skips Modal dispatch when this is unset.
MODAL_FUNCTION_URL=
# ENCRYPTION_KEY is used for AES-256-GCM encryption of user-supplied API keys.
# Any string works for local dev. For production, generate a strong random secret:
#   openssl rand -base64 32
# Then set via: wrangler secret put ENCRYPTION_KEY
ENCRYPTION_KEY=localdev-encryption-key-change-in-production
# ANTHROPIC_API_KEY is used for sponsored plus1 narrations (server-side LLM scripting).
# User-initiated narrations use this key for LLM script improvement + free Microsoft TTS.
# Set via: wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
