# Copy to .dev.vars for local development:
#   cp .dev.vars.example .dev.vars
#
# These override wrangler.toml [vars] and provide secrets locally.
# .dev.vars is gitignored — never commit it.

ADMIN_PASSWORD=localdev
MODAL_WEBHOOK_SECRET=localdev
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# MODAL_FUNCTION_URL is a secret (not in wrangler.toml) — set it here for local dev
# or via `wrangler secret put MODAL_FUNCTION_URL` for production.
# Leave blank locally; the worker skips Modal dispatch when this is unset.
MODAL_FUNCTION_URL=
